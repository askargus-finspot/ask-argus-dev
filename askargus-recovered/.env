# JWT Secret (required for authentication)
JWT_SECRET=askargus-jwt-secret-key-change-in-production-secure-random-string

# Database
MONGO_URI=mongodb://mongodb:27017/AskArgus

# Server
HOST=0.0.0.0
PORT=3080

# Session
SESSION_SECRET=askargus-session-secret-key-change-in-production
REFRESH_TOKEN_SECRET=askargus-refresh-token-secret-key-change-in-production

# Optional: Add other required variables
ALLOW_SOCIAL_LOGIN=false
ALLOW_REGISTRATION=true
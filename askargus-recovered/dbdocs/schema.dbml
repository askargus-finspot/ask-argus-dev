// =============================================================================
// PROMETHEUS TSDB SECTION
// Real metrics from: https://prometheus-fs-le-isv.AskArgus.in/
// 427 metrics pulled live. Presented as logical relational tables.
// =============================================================================

Table prometheus_scrape_target {
  target_id     varchar   [pk, not null, note: 'Synthetic ID: {job}_{instance}']
  job           varchar   [not null, note: 'Scrape job name as configured in prometheus.yml. Observed: kubernetes-apiservers | kubernetes-nodes | kubernetes-cadvisor | kubernetes-service-endpoints | kube-state-metrics | SNMP-{IP} | WINDOWS_EXPORTR-{IP} | router']
  instance      varchar   [not null, note: 'Scraped endpoint label host:port or IP. e.g. 10.10.0.101:6443, 10.10.1.170:9182, 172.20.100.1']
  scrape_url    varchar   [note: 'Actual URL Prometheus calls for scrape. e.g. https://10.10.0.101:6443/metrics, http://prom-snmpexporter-svc.fs-linkedeye:8080/snmp?module={IP}&target={IP}']
  health        varchar   [note: 'Target health status. Observed: up (all active) | down (router: 172.16.0.16). Values: up | down | unknown']
  last_scrape   timestamp [note: 'Timestamp of most recent successful scrape (UTC+05:30)']
  product_model varchar   [note: 'SNMP targets carry this label. Observed: fortigate | huawei | cisco']
  k8s_labels    json      [note: 'Additional Kubernetes/infrastructure labels e.g. kubernetes_namespace, group, beta_kubernetes_io_arch']

  Note: '''
    Live scrape targets from Prometheus at 2026-04-13.
    Active targets: 35+  |  Down targets: 1 (router 172.16.0.16).

    Job categories:
    - kubernetes-apiservers:          K8s API server (10.10.0.101:6443)
    - kubernetes-nodes:               Kubelet on node fs-le-isv
    - kubernetes-cadvisor:            Container resource metrics (cAdvisor)
    - kubernetes-service-endpoints:   CoreDNS (x2), Prometheus self
    - kube-state-metrics:             K8s object state (deployments, pods, etc.)
    - SNMP-172.20.100.1:              FortiGate firewall
    - SNMP-172.20.100.107/108:        Huawei switches
    - SNMP-172.20.100.250:            Cisco device
    - WINDOWS_EXPORTR-10.10.1.{x}:   11 Windows Server nodes (port 9182)
    - router:                         Router exporter — currently DOWN
  '''
}

Table prometheus_metric_metadata {
  metric_name   varchar   [pk, not null, note: 'Prometheus metric name. e.g. node_cpu_seconds_total']
  type          varchar   [not null, note: 'Metric type. Observed values: counter | gauge | histogram | summary | unknown']
  help          text      [note: 'Human-readable description from the exporter /metrics endpoint']
  unit          varchar   [note: 'Metric unit if declared. Usually empty string. e.g. seconds, bytes']
  source_job    varchar   [note: 'Primary scrape job that emits this metric (logical categorisation)']

  Note: '''
    427 real metrics pulled from /api/v1/metadata at 2026-04-13.

    Metric family breakdown by count:
    - counter:   288 metrics (monotonically increasing — use rate() in PromQL)
    - gauge:     200 metrics (instantaneous value — CPU%, memory bytes, etc.)
    - histogram:  74 metrics (bucketed distributions — use histogram_quantile())
    - summary:    18 metrics (quantile distributions — pre-computed)
    - unknown:    47 metrics (node_netstat_*, node_vmstat_* — type undeclared)

    Major metric families:
    - apiserver_*          : Kubernetes API server request/admission metrics
    - kubelet_*            : Kubelet pod/container lifecycle metrics
    - node_*               : Linux node exporter (CPU, memory, disk, net, netstat)
    - windows_*            : Windows exporter (CPU, memory, disk, net, services)
    - coredns_*            : CoreDNS DNS query metrics
    - etcd_*               : etcd key-value store performance
    - go_*                 : Go runtime (GC, goroutines, memory)
    - prometheus_*         : Prometheus self-monitoring (TSDB, scrape, rules)
    - kube_*               : kube-state-metrics (pod/node/deployment states)
    - rest_client_*        : K8s client-go HTTP request metrics
    - workqueue_*          : K8s controller workqueue metrics
    - authentication_*     : K8s authentication duration
    - authorization_*      : K8s authorization duration
    - storage_*            : K8s storage/volume operation metrics

    See prometheus_key_metrics table for the most operationally important subset.
  '''
}

Table prometheus_key_metrics {
  metric_name   varchar   [pk, not null, note: 'Metric name']
  type          varchar   [not null, note: 'counter | gauge | histogram | summary']
  help          text      [note: 'Description']
  typical_labels varchar  [note: 'Common label dimensions for this metric']
  use_case      text      [note: 'Operational use-case / alerting purpose']

  Note: '''
    Curated subset of the 427 metrics most relevant for infrastructure alerting.
    Full list is in prometheus_metric_metadata.

    === KUBERNETES CONTROL PLANE ===
    apiserver_request_total (counter)
      Labels: verb, resource, code, component
      Use: API error rate — alert if 5xx rate > threshold

    apiserver_request_duration_seconds (histogram)
      Labels: verb, resource, subresource
      Use: API latency SLO — histogram_quantile(0.99, ...)

    apiserver_current_inflight_requests (gauge)
      Labels: request_kind (mutating/readOnly)
      Use: Control plane saturation

    etcd_request_duration_seconds (histogram)
      Labels: operation, type
      Use: etcd write/read latency

    === KUBELET / WORKLOADS ===
    kubelet_pod_start_sli_duration_seconds (histogram)
      Use: Pod startup latency SLO

    kubelet_runtime_operations_duration_seconds (histogram)
      Labels: operation_type
      Use: Container runtime (containerd) performance

    kubelet_running_pods (gauge)
      Use: Running pod count per node

    container_cpu_usage_seconds_total (counter) — from cadvisor
      Labels: namespace, pod, container
      Use: Container CPU utilisation

    container_memory_working_set_bytes (gauge) — from cadvisor
      Labels: namespace, pod, container
      Use: Container memory — compare to resource limits

    === NODE / WINDOWS ===
    node_cpu_seconds_total (counter)
      Labels: cpu, mode (idle/iowait/irq/nice/softirq/steal/system/user)
      Use: CPU utilisation = 1 - rate(node_cpu_seconds_total{mode="idle"}[5m])

    node_memory_MemAvailable_bytes (gauge)
      Use: Available memory alert

    node_filesystem_avail_bytes (gauge)
      Labels: device, fstype, mountpoint
      Use: Disk space alert

    node_network_receive_bytes_total / node_network_transmit_bytes_total (counter)
      Labels: device
      Use: Network throughput

    windows_cpu_core_frequency_mhz (gauge)
      windows_memory_available_bytes (gauge)
      windows_logical_disk_free_bytes (gauge)
      windows_net_bytes_received / _sent (counter)
      Use: Windows server resource monitoring for 11 nodes

    === PROMETHEUS SELF ===
    prometheus_tsdb_head_samples_appended_total (counter)
      Use: Ingestion rate — samples/sec

    prometheus_target_scrape_duration_seconds (gauge)
      Use: Slow scrapes alert

    prometheus_rule_evaluation_failures_total (counter)
      Use: Alerting rule breakage detection

    === DNS ===
    coredns_dns_request_duration_seconds (histogram)
      Labels: server, zone, proto, type
      Use: DNS latency SLO

    coredns_dns_responses_total (counter)
      Labels: rcode
      Use: DNS error rate (SERVFAIL/NXDOMAIN)
  '''
}

Table prometheus_series {
  series_id     varchar   [pk, not null, note: 'Synthetic ID: {metric_name}_{labels_hash}']
  metric_name   varchar   [not null, note: 'Metric name — FK to prometheus_metric_metadata']
  labels_json   json      [not null, note: 'Full label-set as JSON. e.g. {"job":"kubernetes-nodes","instance":"fs-le-isv","namespace":"kube-system"}']
  Note: 'One row per unique metric + label-set combination. Prometheus stores each as an independent time series.'
}

Table prometheus_sample {
  series_id   varchar   [not null, note: 'FK to prometheus_series.series_id']
  ts          timestamp [not null, note: 'Sample timestamp (UTC)']
  value       double    [not null, note: 'Sample value as 64-bit float. Integers are exact; special: +Inf, -Inf, NaN']
  Note: 'Individual time-stamped samples. Prometheus default retention = 15 days. Stored in TSDB chunks on disk, not queryable as rows.'
}

// TSDB relationships
Ref: prometheus_series.metric_name > prometheus_metric_metadata.metric_name
Ref: prometheus_sample.series_id > prometheus_series.series_id
Ref: prometheus_metric_metadata.source_job > prometheus_scrape_target.job

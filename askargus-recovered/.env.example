# Copy this file to .env and replace every CHANGE_ME value before running.

HOST=localhost
PORT=3080

JWT_SECRET=CHANGE_ME_GENERATE_64_RANDOM_CHARS
SESSION_SECRET=CHANGE_ME_GENERATE_64_RANDOM_CHARS
REFRESH_TOKEN_SECRET=CHANGE_ME_GENERATE_64_RANDOM_CHARS
REFRESH_SECRET=CHANGE_ME_GENERATE_64_RANDOM_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_64_RANDOM_CHARS
CREDS_KEY=CHANGE_ME_GENERATE_64_RANDOM_CHARS

MONGO_USERNAME=CHANGE_ME_MONGO_USER
MONGO_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGO_URI=mongodb://CHANGE_ME_MONGO_USER:CHANGE_ME_MONGO_PASSWORD@mongodb:27017/AskArgus?authSource=admin

ALLOW_SOCIAL_LOGIN=false
ALLOW_REGISTRATION=false
CONFIG_BYPASS_VALIDATION=false

# GitHub Packages token with read:packages access for @vediyappanm05 packages.
NODE_AUTH_TOKEN=CHANGE_ME_GITHUB_PACKAGES_TOKEN

# Local dev-test MCP backing stores. Keep real values only in .env.
MCP_POSTGRES_DATABASE=askargus_mcp
MCP_POSTGRES_USER=CHANGE_ME_POSTGRES_USER
MCP_POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

MCP_MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MCP_MYSQL_DATABASE=askargus_mcp
MCP_MYSQL_USER=CHANGE_ME_MYSQL_USER
MCP_MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

MCP_NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD
MCP_ELASTICSEARCH_HOST=http://host.docker.internal:9200
MCP_ELASTICSEARCH_APIKEY=CHANGE_ME_ELASTICSEARCH_APIKEY
GOOGLE_KEY=user_provided
